; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Limonchero 3D"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://brqiuopg2hw1l"
driver/enable_input=true

[autoload]

BackendLauncher="*res://scripts/foundation/backend_launcher.gd"
GameManager="*res://scripts/foundation/game_manager.gd"
HUDManager="*res://scenes/ui/hud_manager.tscn"
GajitoPopup="*res://scenes/ui/gajito_popup.tscn"
LLMClient="*res://scripts/foundation/llm_client.gd"
VoiceManager="*res://scripts/core/voice_manager.gd"

[editor_plugins]

enabled=PackedStringArray("res://addons/Tripo3d_Godot_Bridge/plugin.cfg")

[filesystem]

import/blender/enabled=false

[gui]

theme="res://assets/fonts/theme.tres"

[input]

inventory_toggle={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194306,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true

